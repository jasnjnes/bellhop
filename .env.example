# Copy to .env for local development. Never commit the filled-in .env.
# In production these are set as Render environment variables instead.

# --- Required ---

# Fine-grained GitHub personal access token.
# Scope: All repositories, with Administration, Contents, and Pull requests read/write.
# Add Workflows read/write only if agents should modify .github/workflows.
GITHUB_TOKEN=ghp_replace_me

# Fixed OAuth client credentials entered into Claude's connector advanced settings.
# Generate the secret with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_OAUTH_CLIENT_ID=bellhop
MCP_OAUTH_CLIENT_SECRET=replace_me_min_16_chars

# Password typed into the gateway authorization page. Minimum 12 characters.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_LOGIN_PASSWORD=replace_me_min_12_chars

# Signs OAuth codes and tokens. Minimum 32 characters.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# On Render this is generated automatically by render.yaml — do not set it there.
JWT_SECRET=replace_me_min_32_chars

# --- Optional ---

# GitHub account or organization that owns new repositories.
# Defaults to the account the token authenticates as.
GITHUB_DEFAULT_OWNER=

# Public origin used for OAuth discovery and the MCP resource URL.
# Render supplies RENDER_EXTERNAL_URL automatically, so leave this blank there.
# Locally it defaults to http://localhost:8000.
PUBLIC_BASE_URL=

GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10

# Refuse writes that do not supply expected_head. Keep this true.
REQUIRE_EXPECTED_HEAD=true

# Token lifetimes in seconds.
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_CODE_TTL_SECONDS=300

# Brute-force throttle on the authorization password form.
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900

# Result and payload caps.
MAX_TEXT_RESULT_BYTES=120000
MAX_BINARY_INPUT_BYTES=2500000
MAX_COMMIT_FILES=100

# Upload tickets. MAX_BINARY_INPUT_BYTES caps base64 sent through the model's
# context; MAX_UPLOAD_BYTES caps bytes POSTed straight to /upload, which do not.
UPLOAD_TICKET_TTL_SECONDS=300
MAX_UPLOAD_BYTES=26214400
